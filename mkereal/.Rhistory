# --- Libraries ---
library(readxl)
library(ggplot2)
library(dplyr)
library(tidyverse)
library(scales)

# ============================================================
# SECTION 1: Class survey data (df)
# ============================================================

df <- read_excel("/Users/davioncook/Desktop/COSC 4500 5500 Week 1 Excel File.xlsx")

str(df)
summary(df)

# Height histogram (converted to feet)
ggplot(data = df, aes(x = HEIGHT / 12)) +
  geom_histogram(fill = "gray", colour = "black", bins = 50, alpha = 0.9) +
  ggtitle("Height Histogram") +
  ylab("Number of people") +
  xlab("Height (ft)") +
  theme_light()

# Age dot plot
ggplot(data = df, aes(x = AGE)) +
  geom_dotplot(fill = "gray", colour = "black", binwidth = 0.8, stackdir = "centerwhole") +
  scale_y_continuous(breaks = NULL) +
  ggtitle("Age Dotplot") +
  xlab("Age range (yrs)") +
  theme_light() +
  theme(axis.title.y = element_blank())

# Age stem-and-leaf
stem(df$AGE, scale = 1)

# ============================================================
# SECTION 2: Milwaukee real estate (mil)
# ============================================================

mil <- read.csv("/Users/davioncook/Downloads/armslengthsales_2021_valid.csv")

# Filter to residential only and clean Sale_price
new_mil <- mil %>%
  filter(PropType == "Residential") %>%
  mutate(Sale_price = as.integer(gsub("[\\$,]", "", Sale_price)))

# Boxplot: Sale price by district (all residential)
ggplot(data = new_mil, aes(x = District, y = Sale_price)) +
  geom_boxplot() +
  ylim(0, 800000) +
  ggtitle("Sale Price by District (Residential)") +
  ylab("Sale Price ($)") +
  theme_light()

# Boxplot: districts < 5
new_mil %>%
  filter(District < 5) %>%
  ggplot(aes(x = District, y = Sale_price)) +
  geom_boxplot() +
  ylim(0, 800000) +
  ggtitle("Sale Price by District (Districts 1-4)") +
  ylab("Sale Price ($)") +
  theme_light()

# Boxplot: districts >= 5
new_mil %>%
  filter(District >= 5) %>%
  ggplot(aes(x = District, y = Sale_price)) +
  geom_boxplot() +
  ylim(0, 800000) +
  ggtitle("Sale Price by District (Districts 5+)") +
  ylab("Sale Price ($)") +
  theme_light()